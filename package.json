{
  "name": "ami-housekeeping",
  "version": "1.0.0",
  "description": "Lambda housekeeping job that deregisters obsolete AMIs tagged App=POC-Housekeeping and deletes their backing snapshots",
  "main": "dist/index.js",
  "scripts": {
    "build": "esbuild src/index.ts --bundle --platform=node --target=node22 --outfile=dist/index.js",
    "typecheck": "tsc --noEmit",
    "deploy:first": "sam build && sam deploy --guided",
    "rehearse": "aws lambda invoke --function-name ami-housekeeping out.json && type out.json",
    "arm": "sam build && sam deploy --parameter-overrides DryRun=false",
    "disarm": "sam build && sam deploy --parameter-overrides DryRun=true"
  },
  "dependencies": {
    "@aws-sdk/client-ec2": "^3.750.0",
    "esbuild": "^0.25.0"
  },
  "devDependencies": {
    "@types/aws-lambda": "^8.10.145",
    "@types/node": "^22.10.0",
    "typescript": "^5.7.0"
  }
}
